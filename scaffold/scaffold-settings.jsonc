// ============================================================================
// Template settings.json — Agent Autonome
// ============================================================================
//
// Source : Claude Code docs (code.claude.com/docs/en/) + EBSE ai-collaboration
// Usage : copier dans <projet>/.claude/settings.json
//         retirer les commentaires (JSON strict ne supporte pas les //)
//         adapter les [CONFIGURER] selon le projet
//
// Precedence Claude Code (du plus fort au plus faible) :
//   Managed policy > Project .claude/settings.json > User ~/.claude/settings.json > Local .claude/settings.local.json
//
// IMPORTANT : si un .claude/settings.local.json existe avec "defaultMode": "bypassPermissions",
//             il OVERRIDE ce fichier. Supprimer ou modifier le local pour que ce fichier prenne effet.
// ============================================================================

{
  // --- Modele par defaut ---
  // Source: code.claude.com/docs/en/model-config
  // "opusplan" = Opus pour la reflexion/decomposition, Sonnet pour l'execution
  // Optimise le quota : Opus (24-40h/semaine) uniquement pour les plans,
  // Sonnet (240-480h/semaine quasi-illimite) pour l'execution code
  "model": "opusplan",

  // --- Budget caps (PICOC ai-agent-budget-caps GRADE 3 RECOMMANDE) ---
  // Hard-stop sur iterations + escalade PO si breach
  // [CONFIGURER] : ajuster selon complexite des taches du projet
  "maxTurns": 50,

  // --- Permissions ---
  // Source: code.claude.com/docs/en/permission-modes + PICOC #1, #3, #9
  //
  // Philosophie : allow = outils necessaires au travail autonome
  //               deny = operations destructives/irreversibles (PICOC #3 human-only gates)
  //               tout le reste = demande approbation (comportement "auto"-like)
  "permissions": {

    "allow": [
      // ---- Lecture / Ecriture fichiers ----
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",

      // ---- Git (operations non-destructives) ----
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout -b*)",
      "Bash(git branch*)",
      "Bash(git push*)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git stash*)",
      "Bash(git worktree*)",

      // ---- GitHub CLI ----
      "Bash(gh pr*)",
      "Bash(gh issue*)",
      "Bash(gh run*)",

      // ---- Build / Test / Lint (adapter selon stack) ----
      // [CONFIGURER] : decommenter et adapter selon votre stack
      //
      // TypeScript/React :
      // "Bash(pnpm *)",
      // "Bash(npm run *)",
      // "Bash(npx *)",
      //
      // Java/Spring Boot :
      // "Bash(mvn *)",
      // "Bash(./mvnw *)",
      // "Bash(gradle *)",
      //
      // Python/Django :
      // "Bash(python *)",
      // "Bash(pip *)",
      // "Bash(pytest *)",
      // "Bash(ruff *)",
      // "Bash(mypy *)",

      // ---- Package verification (anti-hallucination PICOC #10) ----
      // "Bash(npm info *)",
      // "Bash(pip show *)",

      // ---- Infra (si acces serveur autorise) ----
      // "Bash(ssh *)",
      // "Bash(docker *)",
      // "Bash(docker compose *)",

      // ---- Outils qualite ----
      // "Bash(curl *)",

      // ---- MCP servers ----
      // [CONFIGURER] : decommenter selon vos MCP installes
      // "mcp__playwright__*",
      // "mcp__plugin_context7_context7__*",

      // ---- Web ----
      "WebSearch"
    ],

    "deny": [
      // ---- Destruction fichiers/systeme (PICOC #3 + #9) ----
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(shred*)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(format*)",

      // ---- Git destructif (PICOC #3 human-only gates) ----
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)",
      "Bash(git checkout -- .)",

      // ---- Systeme ----
      "Bash(shutdown*)",
      "Bash(reboot*)",
      "Bash(kill -9 -1*)",
      "Bash(chmod -R 777*)",

      // ---- Docker destructif ----
      "Bash(docker system prune*)",
      "Bash(docker rm -f*)"
    ]
  },

  // --- Hooks ---
  // Source: code.claude.com/docs/en/hooks + PICOC #4, #6 + PICOC ai-agent-extended-hook-lifecycle GRADE 3
  //
  // Hooks de base (tous les projets) :
  //   SessionStart  : charge env + health-check monitoring au demarrage
  //   PreToolUse    : gates qualite avant commit/push/PR
  //   PostToolUse   : lint rapide apres edit + audit trail + cleanup worktree
  //   Stop          : rappel verification avant declaration "done"
  //
  // Hooks avances (activer selon besoin) :
  //   PreCompact      : re-injecte regles MANDATORY avant compaction — activer si sessions > 50K tokens
  //   SubagentStart   : injecte contexte dans sous-agents + log audit — activer si multi-agents
  //   UserPromptSubmit: detection injection + log audit prompts — activer si securite renforcee
  //   PermissionRequest: auto-approuve patterns pre-autorises — activer pour reduire prompts repetitifs
  //
  // Principe de selection (PICOC ai-agent-extended-hook-lifecycle) :
  //   activer uniquement si le scenario a ete observe comme source de defaillance.
  //   chaque hook actif augmente la latence et la complexite de debugging.
  //
  // exit code 0 = continuer | exit code 2 = bloquer l'action + afficher stderr a l'utilisateur
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/session-start.sh" }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/pre-commit-quality.sh" },
          { "type": "command", "command": "bash .claude/hooks/pre-commit-secrets.sh" },
          { "type": "command", "command": "bash .claude/hooks/pre-commit-sast.sh" },
          { "type": "command", "if": "Bash(git push*)", "command": "bash .claude/hooks/pre-push-quality.sh", "timeout": 120 },
          { "type": "command", "if": "Bash(gh pr create*)", "command": "bash .claude/hooks/pre-pr-create.sh", "timeout": 30 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/post-edit-lint.sh" }]
      },
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "if": "Bash(gh pr merge*)", "command": "bash .claude/hooks/post-merge-worktree.sh", "timeout": 30 }]
      },
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/audit-tool-use.sh" }]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/stop-notify.sh" }]
      }
    ],

    // --- Hooks avances --- decommenter selon besoin ---

    // PreCompact : re-injecte regles critiques avant compaction
    // Activer si sessions regulierement > 50K tokens
    // "PreCompact": [
    //   { "hooks": [{ "type": "command", "command": "bash .claude/hooks/pre-compact.sh" }] }
    // ],

    // SubagentStart : injecte contexte dans sous-agents + log audit
    // Activer si architecture multi-agents (PICOC #20 audit trail)
    // "SubagentStart": [
    //   { "hooks": [{ "type": "command", "command": "bash .claude/hooks/subagent-start.sh" }] }
    // ],

    // UserPromptSubmit : detection injection sur chaque message utilisateur
    // Obligatoire si projet utilise GitHub Actions / PR reviews (CVE-2025-54794)
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "bash .claude/hooks/user-prompt-filter.sh" }] }
    ],

    // PermissionRequest : auto-approuve patterns specifiques sans popup
    // Adapter les matchers selon les outils recurrents du projet
    // "PermissionRequest": [
    //   {
    //     "matcher": "Bash(npm run test*)",
    //     "hooks": [{ "type": "command", "command": "bash -c 'echo \"{\\\"action\\\": \\\"allow\\\"}\"'" }]
    //   }
    // ]
  }
}
