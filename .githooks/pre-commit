#!/bin/bash
set -euo pipefail

# Verifie que si decision-tree.json est modifie, les *-recommendations.json sont regeneres

TREE_CHANGED=$(git diff --cached --name-only | grep -q 'data/decision-tree.json' && echo "yes" || echo "no")

if [ "$TREE_CHANGED" = "yes" ]; then
  NEW_VERSION=$(node -e "const f=require('./data/decision-tree.json'); console.log(f.version)" 2>/dev/null || echo "unknown")

  if ! git diff --cached --name-only | grep -q 'data/stacks/ols-recommendations.json'; then
    echo ""
    echo "[hook] ECHEC : data/decision-tree.json modifie (version -> $NEW_VERSION)"
    echo "[hook] Regenerer les recommendations avant de committer :"
    echo "[hook]   node scripts/generate-recommendations.js"
    echo "[hook] Puis : git add data/stacks/*-recommendations.json"
    echo ""
    exit 1
  fi

  echo "[hook] decision-tree.json + recommendations OK"
fi

exit 0
